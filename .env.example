# ==============================================================
# Organizador de Tarefas v3 — Variaveis de Ambiente
# ==============================================================
# Copie este arquivo para .env e preencha os valores.
# NUNCA suba o .env para o GitHub!
# ==============================================================

# --------------------------------------------------------------
# OBRIGATORIAS (o bot nao inicia sem estas 3)
# --------------------------------------------------------------

# Telegram Bot — pegue com @BotFather (/newbot)
# Formato: 1234567890:ABCdefGHIjklMNOpqr
TELEGRAM_BOT_TOKEN=seu_token_aqui

# Supabase — pegue em supabase.com > Settings > API
# Project URL (formato: https://xxxxx.supabase.co)
SUPABASE_URL=https://seu-projeto.supabase.co
# Anon public key (formato: eyJhbGci... — NAO use a service_role)
SUPABASE_ANON_KEY=sua_anon_key_aqui

# --------------------------------------------------------------
# IA — pelo menos uma e necessaria para modo inteligente
# --------------------------------------------------------------

# Gemini API — GRATIS, recomendado (pegue em aistudio.google.com > Get API Key)
# Tier gratuito generoso: 15 req/min, 1500 req/dia
# Formato: AIza...
GEMINI_API_KEY=sua_chave_aqui

# Claude API — fallback pago (pegue em console.anthropic.com > API Keys)
# Usado APENAS se GEMINI_API_KEY nao estiver configurada
# Formato: sk-ant-api03-...
ANTHROPIC_API_KEY=sua_chave_aqui

# --------------------------------------------------------------
# AUDIO — opcional, para transcricao de voz no Telegram
# --------------------------------------------------------------

# Groq API — gratis (pegue em console.groq.com > API Keys)
# Se nao configurar, o bot funciona mas nao transcreve audios
# Formato: gsk_...
GROQ_API_KEY=sua_chave_aqui

# --------------------------------------------------------------
# GOOGLE CALENDAR — opcional, para sincronizar eventos
# --------------------------------------------------------------

# Google OAuth — pegue em console.cloud.google.com > APIs > Credentials
# Crie um "OAuth 2.0 Client ID" do tipo "Web application"
# Adicione redirect URI: https://SEU-APP.koyeb.app/auth/google/callback
GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxx

# --------------------------------------------------------------
# MICROSOFT OUTLOOK/TEAMS — opcional, para sincronizar eventos
# --------------------------------------------------------------

# Microsoft OAuth — pegue em portal.azure.com > App Registrations
# Crie um app com redirect URI: https://SEU-APP.koyeb.app/auth/microsoft/callback
# Permissoes necessarias: Calendars.Read, offline_access, User.Read
MICROSOFT_CLIENT_ID=a1b2c3d4-e5f6-7890-abcd-ef1234567890
MICROSOFT_CLIENT_SECRET=seu_client_secret

# --------------------------------------------------------------
# OAUTH — necessario se usar Google ou Microsoft Calendar
# --------------------------------------------------------------

# URL publica do bot no Koyeb (sem barra no final)
# Usado como base para os callbacks OAuth
BOT_PUBLIC_URL=https://seu-app.koyeb.app

# Chave secreta para assinar o state OAuth (qualquer string aleatoria)
# Protege contra ataques CSRF no fluxo de autorizacao
OAUTH_SECRET_KEY=uma_chave_secreta_aleatoria_qualquer
