# Copie este arquivo para .env e preencha os valores
# NUNCA suba o .env para o GitHub!

# Telegram Bot (pegue com @BotFather)
TELEGRAM_BOT_TOKEN=seu_token_aqui

# Supabase (pegue em supabase.com > Settings > API)
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua_anon_key_aqui

# Gemini API — GRATIS (pegue em aistudio.google.com > Get API Key)
# Recomendado: tier gratuito generoso (15 req/min, 1500 req/dia)
GEMINI_API_KEY=sua_chave_aqui

# Claude API — alternativa paga (pegue em console.anthropic.com)
# Usado apenas se GEMINI_API_KEY nao estiver configurada
ANTHROPIC_API_KEY=sua_chave_aqui

# Groq API — para transcricao de audio (opcional, gratis em console.groq.com)
GROQ_API_KEY=sua_chave_aqui

# Google Calendar OAuth (pegue em console.cloud.google.com > APIs > Credentials)
GOOGLE_CLIENT_ID=seu_client_id
GOOGLE_CLIENT_SECRET=seu_client_secret

# Microsoft/Teams OAuth (pegue em portal.azure.com > App Registrations)
MICROSOFT_CLIENT_ID=seu_client_id
MICROSOFT_CLIENT_SECRET=seu_client_secret

# URL publica do bot no Koyeb (para OAuth callbacks)
BOT_PUBLIC_URL=https://seu-app.koyeb.app

# Chave secreta para assinar OAuth state (qualquer string aleatoria)
OAUTH_SECRET_KEY=uma_chave_secreta_qualquer
